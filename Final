#include <avr/io.h>
#include <avr/interrupt.h>
#include "DHT.h"
#include <LiquidCrystal.h>

// LCD Digital Pins
const int RS = 52, EN = 53, D4 = 44, D5 = 45, D6 = 47, D7 = 46;

// UART
volatile unsigned char *myUCSR0A = (unsigned char *)0x00C0;
volatile unsigned char *myUCSR0B = (unsigned char *)0x00C1;
volatile unsigned char *myUCSR0C = (unsigned char *)0x00C2;
volatile unsigned int  *myUBRR0  = (unsigned int *)0x00C4;
volatile unsigned char *myUDR0   = (unsigned char *)0x00C6;

// Timer (delay)
volatile unsigned char *myTCCR1A = (unsigned char *)0x80;
volatile unsigned char *myTCCR1B = (unsigned char *)0x81;
volatile unsigned char *myTCCR1C = (unsigned char *)0x82;
volatile unsigned char *myTIMSK1 = (unsigned char *)0x6F;
volatile unsigned int  *myTCNT1  = (unsigned int *)0x84;
volatile unsigned char *myTIFR1  = (unsigned char *)0x36;

// ADC registers (NEW)
volatile unsigned char *myADMUX  = (unsigned char *)0x7C;
volatile unsigned char *myADCSRA = (unsigned char *)0x7A;
volatile unsigned int  *myADC    = (unsigned int *)0x78;

#define TBE 0x20

#define PIN_RESET 4
#define PIN_OFF   5
#define PIN_ON    6

#define LED_IDLE      6
#define LED_DISABLED  5
#define LED_RUNNING   4
#define LED_ERROR     3

#define FAN_PIN   6
#define PHOTO_PIN 0

#define DHTPIN  2
#define DHTTYPE DHT11

#define HUMIDITY_THRESHOLD 40
#define TEMP_THRESHOLD 22.8


enum State {
  DISABLED,
  IDLE,
  RUNNING,
  ERROR
};

volatile State currentState = DISABLED;

volatile unsigned char lastPinB = 0xFF;
volatile bool requestIDLE = false;
volatile bool requestDISABLED = false;
volatile bool requestRESET = false;

volatile bool lightSensorError = false;
volatile bool tempHumidSensorError = false;

DHT dht(DHTPIN, DHTTYPE);
LiquidCrystal lcd(RS, EN, D4, D5, D6, D7);

unsigned long lastDHTRead = 0;

void U0init(unsigned long U0baud);
void U0putchar(unsigned char U0pdata);
void U0print_string(const char* str);

void init_hardware(void);
void temp_humid_sensor();
void read_light_sensor();   // NEW
void control_fan(bool turnOn);
void my_delay_ms(unsigned int ms);
void transitionTo(State newState);
void set_leds(bool g, bool y, bool b, bool r);
void update_lcd(float t, float h, State current);

void setup() {
  U0init(9600);
  dht.begin();
  init_hardware();
  sei();
  lcd.begin(16, 2);
  transitionTo(currentState);
}

void loop() {

  if (requestIDLE) {
    requestIDLE = false;
    transitionTo(IDLE);
  }

  if (requestDISABLED) {
    requestDISABLED = false;
    transitionTo(DISABLED);
  }

  if (requestRESET) {
    requestRESET = false;
    tempHumidSensorError = false;
    lightSensorError = false;
    transitionTo(DISABLED);
    transitionTo(IDLE);
  }

  switch (currentState) {

    case DISABLED:
      break;

    case IDLE:
      temp_humid_sensor();
      read_light_sensor();
      break;

    case RUNNING:
      temp_humid_sensor();
      read_light_sensor();
      break;

    case ERROR:
      break;
  }
}

ISR(PCINT0_vect) {

  unsigned char currentB = PINB;

  if (!(currentB & (1 << PIN_ON)) &&
      (lastPinB & (1 << PIN_ON)) &&
      (currentState == DISABLED)) {
    requestIDLE = true;
  }

  if (!(currentB & (1 << PIN_OFF)) &&
      (lastPinB & (1 << PIN_OFF)) &&
      (currentState != DISABLED)) {
    requestDISABLED = true;
  }

  if (!(currentB & (1 << PIN_RESET)) &&
      (lastPinB & (1 << PIN_RESET)) &&
      (currentState == ERROR)) {
    requestRESET = true;
  }

  lastPinB = currentB;
}

void init_hardware(void) {

  DDRB &= ~((1 << PIN_RESET) | (1 << PIN_OFF) | (1 << PIN_ON));
  PORTB |= ((1 << PIN_RESET) | (1 << PIN_OFF) | (1 << PIN_ON));

  DDRH |= (1 << LED_IDLE) | (1 << LED_DISABLED) | (1 << LED_RUNNING) | (1 << LED_ERROR);

  DDRC |= (1 << FAN_PIN);

  DDRC &= ~(1 << PHOTO_PIN);

  *myADMUX = (1 << REFS0);

  *myADCSRA = (1 << ADEN) |
              (1 << ADPS2) |
              (1 << ADPS1) |
              (1 << ADPS0);

  PCICR |= (1 << PCIE0);
  PCMSK0 |= (1 << PCINT6) | (1 << PCINT5) | (1 << PCINT4);
}

void U0init(unsigned long U0baud) {
  unsigned long FCPU = 16000000;
  unsigned int tbaud = (FCPU / 16 / U0baud - 1);

  *myUCSR0A = 0x20;
  *myUCSR0B = 0x18;
  *myUCSR0C = 0x06;
  *myUBRR0 = tbaud;
}

void U0putchar(unsigned char c) {
  while (!(*myUCSR0A & TBE));
  *myUDR0 = c;
}

void U0print_string(const char* str) {
  while (*str) U0putchar(*str++);
}

void control_fan(bool turnOn) {
  if (turnOn) {
    PORTC |= (1 << FAN_PIN);
  } else {
    PORTC &= ~(1 << FAN_PIN);
  }
}

void read_light_sensor() {

  static unsigned long lastPhotoRead = 0;
  unsigned long now = millis();

  if (now - lastPhotoRead >= 500 && currentState != ERROR) {
    lastPhotoRead = now;

    *myADCSRA |= (1 << ADSC);
    while (*myADCSRA & (1 << ADSC));

    unsigned int lightValue = *myADC;

    if (lightValue == 0 || lightValue >= 1020) {
      if (currentState != ERROR) {
        lightSensorError = true;
        U0print_string("ERROR: Light sensor disconnected\n");
        transitionTo(ERROR);
      }
      return;
    }

    char buffer[8];
    itoa(lightValue, buffer, 10);

    if (currentState == IDLE){
      lcd.setCursor(9, 1);
      lcd.print("L:");
      lcd.print(buffer);
      lcd.print(" ");
      U0print_string("Light: " );
      U0print_string(buffer);
      U0print_string("\n");
    }
  }
}

void temp_humid_sensor() {

  unsigned long currentMillis = millis();

  if (currentMillis - lastDHTRead >= 2000) {

    lastDHTRead = currentMillis;

    float h = dht.readHumidity();
    float t = dht.readTemperature();

    if (isnan(h) || isnan(t)) {
      if (currentState != ERROR) {
        tempHumidSensorError = true;
        U0print_string("ERROR: Temperature & Humidity sensor disconnected\n");
        transitionTo(ERROR);
      }
      return;
    }
    if (currentState == IDLE){
      update_lcd(t, h,currentState);
    }
    else{
      update_lcd(t,h,currentState);
    }

    // if (h > HUMIDITY_THRESHOLD) {   // MODIFIED LOGIC
    if (t > TEMP_THRESHOLD) {
      if (currentState == IDLE) {
        transitionTo(RUNNING);
        lcd.setCursor(0, 1);
        lcd.print("H:");
        lcd.print(h);
        lcd.print("% ");
        lcd.print("T:");
        lcd.print(t);
        lcd.print("C");
      }
    } else {
      if (currentState == RUNNING) {
        transitionTo(IDLE);
      }
    }
  }
}

void transitionTo(State newState) {

  currentState = newState;

  switch (newState) {

    case DISABLED:
      U0print_string("STATE: Disabled\n");
      control_fan(false);
      set_leds(0, 1, 0, 0);
      lcd.clear();
      lcd.print("STATE: Disabled");
      break;

    case IDLE:
      U0print_string("STATE: Idle\n");
      control_fan(false);
      set_leds(1, 0, 0, 0);
      lcd.clear();
      // lcd.print("STATE: Idle");
      break;

    case RUNNING:
      U0print_string("STATE: Running\n");
      control_fan(true);
      set_leds(0, 0, 1, 0);
      lcd.setCursor(0, 0);
      break;

    case ERROR:
      U0print_string("STATE: Error\n");
      control_fan(false);
      set_leds(0, 0, 0, 1);
      lcd.clear();
      lcd.print("SENSOR ERROR");
      lcd.setCursor(0, 1);
      if (tempHumidSensorError) {
        lcd.print("Temp. & Humid.");
      } else if (lightSensorError) {
        lcd.print("Light");
      }
      break;
  }
}

void set_leds(bool g, bool y, bool b, bool r) {

  if (g) PORTH |= (1 << LED_IDLE);
  else PORTH &= ~(1 << LED_IDLE);

  if (y) PORTH |= (1 << LED_DISABLED);
  else PORTH &= ~(1 << LED_DISABLED);

  if (b) PORTH |= (1 << LED_RUNNING);
  else PORTH &= ~(1 << LED_RUNNING);

  if (r) PORTH |= (1 << LED_ERROR);
  else PORTH &= ~(1 << LED_ERROR);
}

void update_lcd(float t, float h, State current) {

  char tempBuffer[8];
  char humidBuffer[8];
  
  dtostrf(h, 4, 1, humidBuffer);
  dtostrf(t, 4, 1, tempBuffer);

  U0print_string("Temperature: " );
  U0print_string(tempBuffer);
  U0print_string("     ");
  U0print_string("Humidity: " );
  U0print_string(humidBuffer);
  U0print_string("\n");

  lcd.clear();
  lcd.setCursor(0, 0);
  if(current == IDLE){
    lcd.print("IDLE:  ");
  }
  else{
    lcd.print("RUNNING:  ");
  }
  lcd.print("H:");
  lcd.print(humidBuffer);
  lcd.print("%");

  lcd.setCursor(0, 1);
  lcd.print("T:");
  lcd.print(tempBuffer);
  lcd.print("C");
}
